#!/bin/bash

# ==============================================================================
# AĒR PRE-PUSH HOOK
# Ensures code quality and supply chain security before pushing to the remote.
# ==============================================================================

echo "🛑 [Pre-Push Hook] Running Linters..."

# 1. Run Linters
make lint

if [ $? -ne 0 ]; then
  echo "❌ [Pre-Push Hook] Linting failed! Please fix the errors before pushing."
  exit 1
fi

echo "✅ [Pre-Push Hook] Linting passed."
echo "🛑 [Pre-Push Hook] Running Dependency Audit..."

# 2. Run Dependency Audit (govulncheck + pip-audit)
make audit

if [ $? -ne 0 ]; then
  echo "❌ [Pre-Push Hook] Dependency audit failed! Known vulnerabilities detected."
  echo "   Update affected dependencies before pushing."
  exit 1
fi

echo "✅ [Pre-Push Hook] Dependency audit passed."
echo "🛑 [Pre-Push Hook] Running Tests..."

# 3. Run Tests
make test

if [ $? -ne 0 ]; then
  echo "❌ [Pre-Push Hook] Tests failed! Please fix the failing tests before pushing."
  exit 1
fi

echo "✅ [Pre-Push Hook] Linting, Audit, and Tests passed. Proceeding with push..."
exit 0