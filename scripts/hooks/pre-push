#!/bin/bash

# ==============================================================================
# AĒR PRE-PUSH HOOK
# Local last-line-of-defence against issues that cannot be fixed cheaply
# post-push: code-style drift (lint) and known CVEs in the dependency graph
# (audit). The full test suite runs in CI as the authoritative gatekeeper —
# duplicating it locally adds minutes to every push, drives operators toward
# `--no-verify`, and provides no signal CI does not already provide.
# ==============================================================================

echo "🛑 [Pre-Push Hook] Running Linters..."

# 1. Run Linters
make lint

if [ $? -ne 0 ]; then
  echo "❌ [Pre-Push Hook] Linting failed! Please fix the errors before pushing."
  exit 1
fi

echo "✅ [Pre-Push Hook] Linting passed."
echo "🛑 [Pre-Push Hook] Running Dependency Audit..."

# 2. Run Dependency Audit (govulncheck + pip-audit)
make audit

if [ $? -ne 0 ]; then
  echo "❌ [Pre-Push Hook] Dependency audit failed! Known vulnerabilities detected."
  echo "   Update affected dependencies before pushing."
  exit 1
fi

echo "✅ [Pre-Push Hook] Lint and Audit passed. Tests run in CI. Proceeding with push..."
exit 0