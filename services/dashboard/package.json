{
  "name": "aer-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AĒR Dashboard — SvelteKit static frontend (Phase 97 scaffolding).",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "codegen": "openapi-typescript ../bff-api/api/openapi.bundle.yaml -o src/lib/api/types.ts",
    "bundle-size": "node scripts/check-bundle-size.mjs"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.59.1",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.57.1",
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@types/node": "22.19.17",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-svelte": "3.17.0",
    "globals": "17.5.0",
    "openapi-typescript": "7.13.0",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "3.5.1",
    "rollup-plugin-visualizer": "7.0.1",
    "svelte": "5.55.4",
    "svelte-check": "4.4.6",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.2",
    "vite": "8.0.9",
    "vitest": "4.1.4"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.33.0"
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/context-zone": "2.7.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.215.0",
    "@opentelemetry/instrumentation": "0.215.0",
    "@opentelemetry/instrumentation-fetch": "0.215.0",
    "@opentelemetry/resources": "2.7.0",
    "@opentelemetry/sdk-trace-base": "2.7.0",
    "@opentelemetry/sdk-trace-web": "2.7.0",
    "@opentelemetry/semantic-conventions": "1.40.0"
  }
}
