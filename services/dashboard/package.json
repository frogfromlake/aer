{
  "name": "aer-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AĒR Dashboard — SvelteKit static frontend (Phase 97 scaffolding).",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "messages": "node scripts/messages-if-stale.mjs",
    "messages:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
    "i18n-parity": "node scripts/check-i18n-parity.mjs",
    "sync-papers": "node scripts/sync-papers.mjs",
    "check": "pnpm run messages && svelte-kit sync && echo '▸ svelte-check (type diagnostics — silent until done)…' && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "pnpm run messages && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "pnpm run messages && echo '▸ ESLint (scanning — silent until done)…' && eslint . && echo '▸ Prettier…' && prettier --check . && pnpm run i18n-parity && node scripts/sync-papers.mjs --check",
    "format": "prettier --write .",
    "test:unit": "pnpm run messages && vitest run",
    "test:e2e": "playwright test",
    "codegen": "openapi-typescript ../bff-api/api/openapi.bundle.yaml -o src/lib/api/types.ts",
    "knip": "pnpm run messages && echo '▸ knip (dead-code scan — silent until done)…' && knip",
    "bundle-size": "node scripts/check-bundle-size.mjs",
    "lighthouse": "lhci autorun",
    "bake-landmass": "node scripts/bake-landmass.mjs"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@aer/engine-3d": "workspace:*",
    "@axe-core/playwright": "4.11.2",
    "@eslint/js": "10.0.1",
    "@fontsource-variable/inter": "5.2.8",
    "@fontsource/ibm-plex-mono": "5.2.7",
    "@inlang/paraglide-js": "2.20.0",
    "@lhci/cli": "0.15.1",
    "@playwright/test": "1.59.1",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.57.1",
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@types/d3-sankey": "0.12.5",
    "@types/node": "22.19.17",
    "@types/three": "0.184.0",
    "@vitest/coverage-v8": "4.1.4",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-svelte": "3.17.0",
    "globals": "17.5.0",
    "knip": "5.88.1",
    "openapi-typescript": "7.13.0",
    "pngjs": "7.0.0",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "3.5.1",
    "rollup-plugin-visualizer": "7.0.1",
    "svelte": "5.55.4",
    "svelte-check": "4.4.6",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.2",
    "vite": "8.0.9",
    "vitest": "4.1.4"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.33.0"
  },
  "pnpm": {
    "overrides": {
      "tslib": "2.8.1"
    }
  },
  "dependencies": {
    "@observablehq/plot": "0.6.17",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "0.215.0",
    "@opentelemetry/instrumentation": "0.215.0",
    "@opentelemetry/instrumentation-fetch": "0.215.0",
    "@opentelemetry/resources": "2.7.0",
    "@opentelemetry/sdk-trace-base": "2.7.0",
    "@opentelemetry/sdk-trace-web": "2.7.0",
    "@opentelemetry/semantic-conventions": "1.40.0",
    "@sigma/node-border": "3.0.0",
    "@tanstack/svelte-query": "6.1.18",
    "d3-sankey": "0.12.3",
    "diff": "9.0.0",
    "graphology": "0.26.0",
    "graphology-communities-louvain": "2.0.2",
    "graphology-layout-forceatlas2": "0.10.1",
    "graphology-types": "0.24.8",
    "html-to-image": "1.11.13",
    "sigma": "3.0.3",
    "three": "0.184.0",
    "uplot": "1.6.32"
  }
}
