{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreDependencies": ["@fontsource-variable/inter", "@fontsource/ibm-plex-mono"],
  "rules": {
    "files": "error",
    "dependencies": "error",
    "devDependencies": "error",
    "unlisted": "error",
    "binaries": "error",
    "unresolved": "error",
    "exports": "off",
    "types": "off",
    "nsExports": "off",
    "nsTypes": "off",
    "enumMembers": "off",
    "duplicates": "off"
  }
}
