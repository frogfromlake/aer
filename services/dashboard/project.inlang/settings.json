{
  "$schema": "https://inlang.com/schema/project-settings",
  "baseLocale": "en",
  "locales": ["en", "de"],
  "modules": ["https://cdn.jsdelivr.net/npm/@inlang/plugin-message-format@4/dist/index.js"],
  "plugin.inlang.messageFormat": {
    "pathPattern": [
      "./messages/{locale}/common.json",
      "./messages/{locale}/base.json",
      "./messages/{locale}/chrome.json",
      "./messages/{locale}/atmosphere.json",
      "./messages/{locale}/workbench.json",
      "./messages/{locale}/levers.json",
      "./messages/{locale}/cells.json",
      "./messages/{locale}/evidence.json",
      "./messages/{locale}/dossier.json",
      "./messages/{locale}/source.json",
      "./messages/{locale}/auth.json",
      "./messages/{locale}/account.json",
      "./messages/{locale}/reflection.json",
      "./messages/{locale}/metadata.json",
      "./messages/{locale}/errors.json",
      "./messages/{locale}/domain.json"
    ]
  }
}
