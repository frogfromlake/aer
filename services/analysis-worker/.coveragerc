# Coverage config — analysis-worker (Phase 142 / ADR-041).
# Floors the worker's business logic (internal/ + extractors + main.py logic).
# Entrypoint glue is excluded via `# pragma: no cover` at the call site and the
# `if __name__` clause below — testing NATS/lifecycle wiring carries low signal
# (ADR-041 denominator convention). Threshold ratchets to 80 in Phase-142 Step 5.
[run]
source = .
omit =
    tests/*
    scripts/*
    data/*
    .venv/*
    */__pycache__/*

[report]
# Phase-142: ratcheted to the ADR-041 80% floor. The final climb from 76 came
# from the revision-diff sweep orchestration (run_revision_diff_sweep) plus the
# metadata-coverage / probe-scope / logging / reattempt small units.
fail_under = 80
show_missing = True
exclude_also =
    if __name__ == .__main__.:
    raise NotImplementedError
