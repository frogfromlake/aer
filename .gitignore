# IDEs and OS
.vscode/
.idea/
.DS_Store
*.swp

# Go
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# Python
__pycache__/
*.py[cod]
*$py.class
venv/
env/
.env
# Phase 155 / ADR-046: local Docker-secrets staging dir (stage_secrets_local.sh
# writes the .env secrets here for `make up`). Never commit — it holds secrets.
.aer-secrets/
# Phase 155 / D9: generated non-secret runtime env (gen_runtime_env.sh). Derived
# from .env; regenerated on every `make up` / deploy.
.env.runtime
services/analysis-worker/.venv
crawlers/web-crawler/.audit-venv/
# Phase 122g: backup files written by `aer-audit-source` when an
# operator accepts a re-audit diff that mutates probes/*/sources.yaml.
crawlers/web-crawler/probes/**/sources.yaml.bak

# Docker / MkDocs
site/

# services ingestion-api
services/ingestion-api/.env

# Crawler binaries
crawlers/wikipedia-scraper/wikipedia-scraper

# Crawler state
*.rss-crawler-state.json
# Logs
logs/
*.log
.pids

# Misc
.claude/
CLAUDE.md
repomix-output.xml
services/analysis-worker/data/sentiws/SentiWS_v2.0_Negative.txt
services/analysis-worker/data/sentiws/SentiWS_v2.0_Positive.txt
LOCAL_NOTES.md
# OpenAPI bundled artifacts — generated by `make openapi-bundle`, consumed by codegen
services/*/api/openapi.bundle.yaml
TESTING.md

# Frontend (services/dashboard/) — see services/dashboard/.gitignore for the
# service-local rules; these keep the repo root tidy when running tooling from root.
node_modules/
.svelte-kit/
services/dashboard/build/
services/dashboard/playwright-report/
services/dashboard/test-results/
services/dashboard/coverage/
services/dashboard/packages/engine-3d/coverage/

# Coverage data/artefacts (Phase 142). coverage.py writes a binary .coverage
# SQLite DB at the cwd it runs in; never commit it. HTML/XML reports likewise.
.coverage
.coverage.*
coverage.xml
htmlcov/

# Wikidata index build-context staging (Phase 118b)
# Populated by scripts/build_wikidata_index.py output before docker build;
# kept out of git so the 134 MB SQLite never lands in a commit.
infra/wikidata-index/data/

# Phase-planning working log (senior-architect discussion 2026-05-18).
# Working material consumed during the ROADMAP rewrite, not a repo artefact.
.aer-phase-decisions.md
.aer-roadmap-backup.md
.roadmap-*.tmp

# Private security findings — NEVER commit (public repo). Stage-A register, threat models, repro notes.
.security/

# Deploy-prep guide (local only, not project docs)
aer_deploy_tasks.md

# Per-box deploy state — last-deployed commit SHA, written by
# scripts/operations/deploy_pull.sh to scope the prometheus/grafana config
# reload. Created on the box at runtime, never committed.
.aer-deployed-sha
