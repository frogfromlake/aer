# ==========================================
# GLOBAL APP SETTINGS
# ==========================================
APP_ENV=development
LOG_LEVEL=DEBUG

# ==========================================
# INFRASTRUCTURE (DOCKER COMPOSE SECRETS)
# ==========================================
POSTGRES_USER=aer_admin
POSTGRES_PASSWORD=aer_secret
POSTGRES_DB=aer_metadata
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=aer_gold
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9002

# ==========================================
# NATS MESSAGE BROKER
# ==========================================
NATS_URL=nats://localhost:4222

# ==========================================
# GO SERVICES CONFIGURATION
# ==========================================
INGESTION_PORT=8081
DB_URL=postgres://aer_admin:aer_secret@localhost:5432/aer_metadata?sslmode=disable
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
BFF_PORT=8080
BFF_API_KEY=change-me-in-production
INGESTION_API_KEY=change-me-in-production
ACME_EMAIL=your-email@example.com
GRAFANA_HOST=grafana.example.com
MINIO_CONSOLE_HOST=minio.example.com

# ==========================================
# ANALYSIS WORKER (PYTHON)
# ==========================================
WORKER_COUNT=5

# ==========================================
# OBSERVABILITY (OpenTelemetry)
# ==========================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ==========================================
# GRAFANA
# ==========================================
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
