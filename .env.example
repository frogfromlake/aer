# ==========================================
# REQUIRED SECRETS (boot- or infra-validated)
# ==========================================
# Every value marked REPLACE-ME below is a placeholder. The repository keeps
# zero default credentials in version control. For local dev, copy this file
# to .env and substitute real values. In CI, GitHub Actions Secrets are
# spliced into .env before the smoke test runs.
#
# Generate strong secrets with:
#   openssl rand -base64 32
#
# Boot-validated (service refuses to start if empty):
#   bff-api       → BFF_API_KEY, CLICKHOUSE_PASSWORD, BFF_DB_USER, BFF_DB_PASSWORD,
#                   BFF_AUTH_DB_USER, BFF_AUTH_DB_PASSWORD
#   ingestion-api → INGESTION_API_KEY, DB_URL (embeds POSTGRES_PASSWORD)
#
# MinIO-validated (minio-init fails if any are empty):
#   INGESTION_MINIO_ACCESS_KEY / INGESTION_MINIO_SECRET_KEY
#   WORKER_MINIO_ACCESS_KEY    / WORKER_MINIO_SECRET_KEY
#
# Postgres-validated (postgres-init-roles provisions the BFF Postgres roles):
#   BFF_DB_USER / BFF_DB_PASSWORD            — read-only role, SELECT only (Phase 87)
#   BFF_AUTH_DB_USER / BFF_AUTH_DB_PASSWORD  — auth write role, DML on the auth
#                                              tables only (Phase 134 / ADR-040)
#
# ==========================================
# GLOBAL APP SETTINGS
# ==========================================
APP_ENV=development
LOG_LEVEL=DEBUG

# ==========================================
# POSTGRES (METADATA STORE)
# ==========================================
POSTGRES_USER=aer_admin
POSTGRES_PASSWORD=REPLACE-ME  # REQUIRED — embedded in DB_URL
POSTGRES_DB=aer_metadata
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# For local development, uncomment to point to the migrations directory directly.
# Note: do NOT add a "file://" prefix — the ingestion API prepends it automatically.
# MIGRATIONS_PATH=./infra/postgres/migrations

# ==========================================
# MINIO (OBJECT STORE)
# ==========================================
# Root credentials — used ONLY by the minio server container and minio-init
# (setup.sh). Long-running services use the per-service accounts below.
MINIO_ROOT_USER=REPLACE-ME
MINIO_ROOT_PASSWORD=REPLACE-ME
# Service account credentials provisioned by infra/minio/setup.sh.
# Per-service least-privilege policies are defined there.
INGESTION_MINIO_ACCESS_KEY=REPLACE-ME
INGESTION_MINIO_SECRET_KEY=REPLACE-ME
WORKER_MINIO_ACCESS_KEY=REPLACE-ME
WORKER_MINIO_SECRET_KEY=REPLACE-ME
# BFF service account — read-only on silver/bronze for L5 Evidence (Phase 101).
BFF_MINIO_ACCESS_KEY=REPLACE-ME
BFF_MINIO_SECRET_KEY=REPLACE-ME

# ==========================================
# CLICKHOUSE (GOLD LAYER)
# ==========================================
CLICKHOUSE_USER=aer_user
CLICKHOUSE_PASSWORD=REPLACE-ME  # REQUIRED — bff-api refuses to boot if empty
CLICKHOUSE_DB=aer_gold
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9002

# ==========================================
# NATS MESSAGE BROKER
# ==========================================
NATS_URL=nats://localhost:4222

# ==========================================
# GO SERVICES CONFIGURATION
# ==========================================
INGESTION_PORT=8081
# REQUIRED — ingestion-api refuses to boot if empty. Embeds POSTGRES_PASSWORD.
DB_URL=postgres://aer_admin:REPLACE-ME@localhost:5432/aer_metadata?sslmode=disable
# Hard cap on the JSON body accepted by POST /api/v1/ingest (Phase 82).
# A request larger than this is rejected with 413 before the decoder runs.
INGESTION_MAX_BODY_BYTES=16777216  # 16 MiB
# Grace period for draining in-flight requests on SIGTERM (Phase 82).
# Must exceed the HTTP WriteTimeout (60s) so a mid-flight batch can finish.
INGESTION_SHUTDOWN_TIMEOUT_SECONDS=65
# PostgreSQL connection pool sizing (Phase 85). Symmetric with the analysis
# worker's psycopg2 pool so neither side starves under WORKER_COUNT scale-up.
INGESTION_DB_MAX_OPEN_CONNS=25
INGESTION_DB_MAX_IDLE_CONNS=5
INGESTION_DB_CONN_MAX_LIFETIME_MINUTES=30
# Parallel MinIO uploads per /api/v1/ingest batch (Phase 85). 8 matches the
# default MinIO connection pool breathing room under typical batch sizes.
INGESTION_MINIO_UPLOAD_CONCURRENCY=8
MINIO_ENDPOINT=localhost:9000
MINIO_USE_SSL=false
# Bronze bucket name, consumed by both ingestion-api (writes) and
# analysis-worker (reads). Two services, one truth — keep them aligned.
INGESTION_BRONZE_BUCKET=bronze
BFF_PORT=8080
# REQUIRED — bff-api refuses to boot if empty. Generate with `openssl rand -base64 32`.
BFF_API_KEY=REPLACE-ME
BFF_METRICS_CACHE_TTL_SECONDS=60
# Grace period for draining in-flight requests on SIGTERM (Phase 82).
# Must exceed the HTTP WriteTimeout (60s) and chi request timeout (30s).
BFF_SHUTDOWN_TIMEOUT_SECONDS=65
# Dedicated read-only Postgres role backing GET /api/v1/sources (Phase 87).
# The postgres-init-roles init container creates this role on first boot
# and ALTERs the password on every stack restart, so rotating the value
# here is just `docker compose up -d` away. The role only ever holds
# SELECT on the public.sources table — if you see it GRANTed anywhere
# else, something is off.
BFF_DB_USER=bff_readonly
BFF_DB_PASSWORD=REPLACE-ME
# Dedicated WRITE Postgres role for the auth tables (Phase 134 / ADR-040).
# The BFF is the confidential auth authority and opens a SECOND, small pool
# under this role for users/sessions/auth_tokens (and, from Phase 135,
# saved_analyses). It is separate from BFF_DB_USER so the analytics read
# path keeps zero write authority — least-privilege (CLAUDE.md Security
# Defaults). postgres-init-roles creates it and re-syncs the password on
# every stack restart, exactly like the read-only role above. The role only
# ever holds DML on the auth tables — if you see it elsewhere, something is
# off.
BFF_AUTH_DB_USER=bff_auth
BFF_AUTH_DB_PASSWORD=REPLACE-ME
# Session + cookie tuning (ADR-040). Defaults are production-safe; override
# only with reason. BFF_SECURE_COOKIES MUST stay true in any real deployment
# (it yields the `__Host-`-prefixed Secure cookie). Set it false ONLY for
# local http / Testcontainers, where Secure-over-https would drop the cookie.
BFF_SECURE_COOKIES=true
BFF_SESSION_IDLE_SECONDS=28800        # 8 h sliding idle window
BFF_SESSION_ABSOLUTE_SECONDS=604800   # 7 d hard cap (forces re-auth)
# argon2id password-hashing cost (OWASP defaults: m=19 MiB, t=2, p=1).
BFF_ARGON2_MEMORY_KIB=19456
BFF_ARGON2_ITERATIONS=2
BFF_ARGON2_PARALLELISM=1
# Single-use token lifetimes (seconds): reset is short, invite is longer.
BFF_PASSWORD_RESET_TTL_SECONDS=3600   # 1 h
BFF_INVITE_TTL_SECONDS=259200         # 72 h
# Origin used to build invite / reset links (e.g. https://aer.example). Empty
# yields relative links; set this to the deployed origin so emailed links work.
# SEC-036/039: when APP_ENV=production the BFF refuses to boot unless this is a
# non-localhost https:// origin (an empty/localhost value silently produces dead
# links). Set it to https://${DASHBOARD_HOST}.
BFF_PUBLIC_BASE_URL=
# --- Transactional email (Phase 153 / ADR-043) -------------------------------
# Provider-agnostic SMTP submission relay for invite / password-reset emails.
# Default provider: Brevo (EU/DSGVO, 300 mails/day free) — any relay that speaks
# SMTP submission with STARTTLS works; the choice is pure config.
# Leave SMTP_HOST EMPTY to fall back to the LogSender (links logged, not
# emailed) — fine for local dev and the `make create-admin` break-glass path.
# When SMTP_HOST is set, USERNAME/PASSWORD/FROM_ADDRESS are required at boot.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=REPLACE-ME
SMTP_PASSWORD=REPLACE-ME
SMTP_FROM_ADDRESS=REPLACE-ME
SMTP_FROM_NAME=AĒR
# Email of the first admin account, seeded by `make create-admin` (ADR-040).
# Self-registration is closed, so the first admin is bootstrapped out of band;
# the tool prints an accept-invite link for this address.
ADMIN_BOOTSTRAP_EMAIL=REPLACE-ME
# WebAuthn / passkey relying-party (Phase 134 / ADR-040). RP_ID is the
# registrable domain (no scheme/port); RP_ORIGINS is a comma-separated list of
# full browser origins the authenticator may present — EACH must match the page
# origin exactly (scheme + host + port). Passkey registration fails origin
# verification otherwise. For local dev include BOTH the Traefik TLS origin
# (https://localhost) AND the Vite dev server (http://localhost:5173), since the
# browser page origin is whichever one you opened. In production set RP_ID +
# RP_ORIGINS to the deployed domain only.
# SEC-039: when APP_ENV=production the BFF refuses to boot if RP_ID is localhost
# or RP_ORIGINS still contains localhost (browsers reject passkeys whose RP does
# not match the page origin). Set RP_ID=${DASHBOARD_HOST}, RP_ORIGINS=https://${DASHBOARD_HOST}.
BFF_WEBAUTHN_RP_ID=localhost
BFF_WEBAUTHN_RP_DISPLAY_NAME=AĒR
BFF_WEBAUTHN_RP_ORIGINS=https://localhost,http://localhost:5173
# TTL for the in-memory /sources cache. 60s is plenty since the source
# list only changes on a schema migration.
BFF_SOURCES_CACHE_TTL_SECONDS=60
# Directory holding the bundled BFF config files (metric_provenance.yaml,
# content/). The container build copies them to /app/configs and runs from
# /app, so the default `configs` resolves correctly. For host-mode runs
# (`make services-up`) the binary is launched from the repo root, so
# uncomment the override below.
# BFF_CONFIG_DIR=services/bff-api/configs
# REQUIRED — ingestion-api refuses to boot if empty. Generate with `openssl rand -base64 32`.
INGESTION_API_KEY=REPLACE-ME
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8089
ACME_EMAIL=your-email@example.com
# SEC-042 — ACME CA directory. Leave EMPTY for real Let's Encrypt certs. For a
# first deploy / DNS-still-propagating dry-run, set the STAGING directory to
# avoid burning LE's weekly rate limit on a misconfig (certs will be untrusted),
# then clear it + re-up for a trusted cert:
#   ACME_CA_SERVER=https://acme-staging-v02.api.letsencrypt.org/directory
ACME_CA_SERVER=

# ==========================================
# ANALYSIS WORKER (PYTHON)
# ==========================================
WORKER_COUNT=4
# Phase 123 — JetStream consumer tuning. ack_wait must exceed worst-case
# per-document processing time (heavy NLP under backlog) so a still-processing
# document is never redelivered.
NATS_ACK_WAIT_SECONDS=300
NATS_MAX_DELIVER=5
# Phase 123 — CRITICAL for WORKER_COUNT>1. HuggingFace `tokenizers` (Rust/rayon)
# deadlocks when the BERT models are tokenised from multiple Python threads at
# once; disabling its internal parallelism removes the deadlock. Bound the math
# libraries to 1 intra-op thread each so concurrent inferences don't explode the
# process thread count — parallelism comes from the worker pool.
TOKENIZERS_PARALLELISM=false
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
# Bronze bucket the worker reads from. Must match INGESTION_BRONZE_BUCKET.
WORKER_BRONZE_BUCKET=bronze
# Timeout in seconds for acquiring a ClickHouse client from the pool (Phase 91).
# If a client is not available within this window, the worker raises TimeoutError
# instead of blocking indefinitely.
CLICKHOUSE_POOL_TIMEOUT_SECONDS=30
# PostgreSQL statement_timeout for worker queries (Phase 91). Prevents a slow
# or deadlocked Postgres query from consuming a worker thread indefinitely.
WORKER_PG_STATEMENT_TIMEOUT_MS=5000
# Graceful-shutdown drain window on SIGTERM (closes ClickHouse + Postgres pools).
# The compose `stop_grace_period` (70s) is set to exceed this so Docker does not
# SIGKILL the worker mid-drain on a redeploy. Keep grace > this value if raised.
WORKER_SHUTDOWN_TIMEOUT_SECONDS=65
# Stale-claim reaper: a document whose processing claim is older than the
# THRESHOLD is considered abandoned (e.g. a crashed worker) and re-queued; the
# REAPER_INTERVAL is the scan cadence. Threshold must exceed the longest healthy
# per-document processing time so a live worker is never robbed of its claim.
WORKER_STALE_PROCESSING_THRESHOLD_SECONDS=900
WORKER_STALE_PROCESSING_REAPER_INTERVAL_SECONDS=120
# BUILD-TIME ONLY (compose build arg, not a runtime var). Source URL for the
# SentiWS German sentiment lexicon baked into the analysis-worker image. Leave
# empty to use the canonical Leipzig mirror. If that academic server is down
# (it has periodic outages), set a byte-identical fallback — e.g. an Internet
# Archive snapshot:
#   SENTIWS_URL=https://web.archive.org/web/20251206011040/https://downloads.wortschatz-leipzig.de/etc/SentiWS/SentiWS_v2.0.zip
# The SHA256 pin in services/analysis-worker/Dockerfile verifies the bytes, so a
# fallback mirror cannot weaken supply-chain integrity (wrong file → build fails).
SENTIWS_URL=
# Phase 122e A26 / F-A26 — analytical-window cutoff. Articles whose
# extracted `core.timestamp` (true `published_date`) is older than this
# many days are PRESERVED in the Silver MinIO archive layer but EXCLUDED
# from ClickHouse analytics inserts (`aer_silver.documents`,
# `aer_gold.metrics`, `aer_gold.entities`, etc.). This implements the
# canonical scientific-data pattern *archives are immutable; analytics
# are bounded* — without it, an old republished article would be
# inserted then evicted on the next merge by the schema's
# `TTL timestamp + toIntervalDay(365)`, producing transient raw-vs-MV
# drift and wasting NER + sentiment compute. Default 365 matches the
# CH TTL on `aer_silver.documents` and `aer_gold.metrics`. The
# Prometheus counter `analysis_worker_archived_only_total{source}`
# surfaces the per-source exclusion count.
WORKER_ANALYTICAL_WINDOW_DAYS=365

# --- Silent-Edit Observability (Phase 122d.0 / ADR-032) -----------------
#
# The Wayback Machine CDX API is the independent third-party witness
# for silent edits — publishers revising articles without notice (WP-003 §5).
# The WebAdapter queries CDX as the last step of harmonisation and
# records the result on `WebMeta.wayback_revisions` + `wayback_lookup_status`.
# The processor projects each detected revision into
# `aer_gold.article_revisions`; the BFF surfaces aggregate edit
# activity via `/revisions` (Aleph + Episteme cells) and the per-article
# snapshot list via `/articles/{id}/revisions` (L5EvidenceReader).
#
# Failure mode: a CDX timeout / outage / rate-limit denial NEVER produces
# a DLQ event. Every error path collapses to `wayback_lookup_status=failed`
# on the article and the rest of the pipeline continues. Disabling the
# integration entirely (the default below) leaves the column blank, so
# the BFF can render "we did not look" distinctly from "we looked, the
# URL is not archived".
#
# Local dev override: set ENABLED=true to exercise the lookup end-to-end.
# Rate-limit budget: the public CDX endpoint is shared infrastructure;
# 5 req/s is a polite per-worker default. Raise only if you operate
# under coordination with the Internet Archive.
WAYBACK_CDX_ENABLED=true
WAYBACK_CDX_BASE_URL=https://web.archive.org/cdx/search/cdx
# ADR-036 — INLINE (ingest hot path): fail-fast (short timeout + 1 retry; the
# breaker bounds the blast radius, the re-attempt loop recovers misses). The
# SWEEP client (WAYBACK_CDX_REATTEMPT_*) is patient.
WAYBACK_CDX_TIMEOUT_SECONDS=5.0
WAYBACK_CDX_INLINE_MAX_RETRIES=1
WAYBACK_CDX_REATTEMPT_TIMEOUT_SECONDS=30.0
WAYBACK_CDX_REATTEMPT_MAX_RETRIES=3
WAYBACK_CDX_RATE_LIMIT_PER_SECOND=5.0
# Cache TTL — silent edits move on a day-scale, so 24 h re-fetching keeps
# the corpus current without burning the CDX rate budget on warm reads.
WAYBACK_CDX_CACHE_TTL_HOURS=24
# Phase 123 — circuit breaker: open after N consecutive CDX failures and skip
# lookups for the cooldown, so an unreachable Internet Archive never throttles
# the per-article processing path.
WAYBACK_CDX_CIRCUIT_FAILURE_THRESHOLD=5
WAYBACK_CDX_CIRCUIT_RESET_SECONDS=60
# ADR-036 — enrichment completeness & periodic re-attempt. A general in-worker
# loop that re-attempts per-article enrichments whose ingest-time lookup was
# incomplete (e.g. Wayback while IA was unreachable), so transient gaps
# self-heal instead of needing a re-crawl. Runs at boot + every interval.
ENRICHMENT_REATTEMPT_ENABLED=true
ENRICHMENT_REATTEMPT_INTERVAL_SECONDS=1800
ENRICHMENT_REATTEMPT_BATCH_LIMIT=200
ENRICHMENT_REATTEMPT_INITIAL_DELAY_SECONDS=120
# Republication-trigger threshold — when `sitemap_lastmod` exceeds the
# article's `published_date` by this many days, the worker emits a
# `republication_trigger` row alongside any CDX rows. 7 days suppresses
# small sitemap-cache jitter; lower it to catch tighter re-list events.
REPUBLICATION_TRIGGER_MIN_DELTA_DAYS=7

# --- Silent-Edit Diff Substance (Phase 122d.1 / ADR-032 amendment) ------
#
# After Phase 122d.0 makes silent-edit activity *observable* (which sources
# edit, how often), 122d.1 makes the *substance* of each edit observable:
# the worker runs a periodic sweep that fetches archived Wayback HTML for
# every undiffed consecutive `cdx_snapshot` pair in `aer_gold.article_revisions`,
# re-runs trafilatura at parity with Bronze→Silver, and computes a
# paragraph-aligned diff + headline-change detection.
#
# Failure mode: a missing snapshot, a timeout, or a rate-limit denial
# NEVER produces a DLQ event. The affected pair is logged and skipped;
# the next sweep tick re-attempts.
#
# Separate enable-flag from CDX so an operator can run with CDX enabled
# (revision counts visible) but diff disabled (e.g. IA full-HTML bandwidth
# constrained).
REVISION_DIFF_EXTRACTION_ENABLED=false
REVISION_DIFF_EXTRACTION_INTERVAL_SECONDS=3600
REVISION_DIFF_EXTRACTION_INITIAL_DELAY_SECONDS=180
# Per-tick cap on pairs processed. Bounds the IA-rate-limit budget and
# the CPU spent on trafilatura re-extraction.
REVISION_DIFF_MAX_PAIRS_PER_TICK=200
# Snapshot fetcher rate limit + timeout — separate budgets from the CDX
# lookup; IA prefers a lower rate for full-HTML fetches than for CDX
# queries.
WAYBACK_SNAPSHOT_TIMEOUT_SECONDS=15.0
WAYBACK_SNAPSHOT_RATE_LIMIT_PER_SECOND=2.0

# --- Background loop cadence ---------------------------------------------
#
# All values below are TIMING knobs only (interval + initial delay).
# Scientific parameters — lookback windows, baseline retention, language
# partitioning, equivalence gates — are NOT exposed here and MUST NOT be
# tuned for development convenience.
#
# Local-development reality: a session is hours, not days, so the
# production cadences (24 h baselines, weekly topics) never fire during
# a working session. Recommended dev overrides are commented next to
# each variable. To revert to production cadence, simply unset the
# override or restore the noted production value.
# -------------------------------------------------------------------------

# Phase 102: corpus-extraction loop (EntityCoOccurrenceExtractor). The loop
# runs in-process every CORPUS_EXTRACTION_INTERVAL_SECONDS and sweeps the
# previous CORPUS_EXTRACTION_WINDOW_SECONDS of aer_gold.entities for every
# active source. Idempotent via ReplacingMergeTree(ingestion_version), so
# overlapping or repeated sweeps deduplicate at merge time. Set
# CORPUS_EXTRACTION_ENABLED=false to disable in environments without
# pre-existing entity data (e.g. local smoke tests).
#
# Phase 131a (BUG 1.5) — the previous "previous hour" window silently
# dropped every entity-bearing article whose published_date was outside
# the rolling 1h window. With a 7-day crawler watermark and hourly
# sweeps that meant ~99% of the corpus never produced co-occurrence
# rows. The fix: widen the window to cover the full Gold entities TTL
# (365 days). Per-article window_start = article.published_date keeps
# the row PK stable, so re-sweeps collapse under
# ReplacingMergeTree(ingestion_version) without storage bloat.
#
# Production cadence: hourly sweep over the full 365-day window. Dev
# override: drop CORPUS_EXTRACTION_INTERVAL_SECONDS to 300 (5 min) so a
# fresh crawl produces co-occurrence rows within one session.
CORPUS_EXTRACTION_ENABLED=true
CORPUS_EXTRACTION_INTERVAL_SECONDS=3600
CORPUS_EXTRACTION_WINDOW_SECONDS=31536000
CORPUS_EXTRACTION_INITIAL_DELAY_SECONDS=60

# Phase 115: baseline-maintenance loop (MetricBaselineExtractor). Computes
# per-(metric, source, language) means and standard deviations over a 90-day
# rolling window, written to aer_gold.metric_baselines. Drives the
# Normalization control (z-score / percentile) on the dashboard once an
# equivalence row also exists in aer_gold.metric_equivalence (Phase 126).
#
# The 90-day window is the SCIENTIFIC parameter (matches Bronze TTL +
# operations-playbook default for cross-source baseline comparability) —
# do NOT shorten it for development. Adjust only the cadence below.
#
# Dev override: BASELINE_EXTRACTION_INTERVAL_SECONDS=600 (10 min) and
# BASELINE_EXTRACTION_INITIAL_DELAY_SECONDS=60 so baselines populate within
# minutes of the first crawl. Prod default is daily (86400) because
# baselines move slowly relative to per-document metrics.
BASELINE_EXTRACTION_ENABLED=true
BASELINE_EXTRACTION_INTERVAL_SECONDS=86400
BASELINE_EXTRACTION_WINDOW_SECONDS=7776000
BASELINE_EXTRACTION_INITIAL_DELAY_SECONDS=300

# Phase 120: BERTopic topic-modeling loop (TopicModelingExtractor). Reads
# Silver documents over a 30-day rolling window, fits BERTopic per detected
# language partition (WP-004 §3.4 — no forced cross-lingual alignment),
# writes one row per (article_id, topic_id) to aer_gold.topic_assignments.
#
# Default DISABLED until the heavier image (multilingual-e5-large, ~2.2 GB)
# is deployed and the operator opts in by setting TOPIC_EXTRACTION_ENABLED=true.
# The 30-day window is the SCIENTIFIC parameter (WP-001 §3.3 topic-stability
# horizon) — do NOT shorten it for development.
#
# Dev override (when ENABLED): TOPIC_EXTRACTION_INTERVAL_SECONDS=600 and
# TOPIC_EXTRACTION_INITIAL_DELAY_SECONDS=120 so the first sweep fires ~2 min
# after worker boot and topic assignments appear within one dev session.
# Prod default is weekly (604800) because BERTopic is computationally heavy
# and topics are not expected to drift on a sub-week timescale.
TOPIC_EXTRACTION_ENABLED=false
TOPIC_EXTRACTION_INTERVAL_SECONDS=604800
TOPIC_EXTRACTION_WINDOW_SECONDS=2592000
TOPIC_EXTRACTION_INITIAL_DELAY_SECONDS=600

# Phase 118: Wikidata alias index for entity linking. The DB is populated
# into the wikidata_data named volume by the wikidata-index-init compose
# service from the aer-wikidata-index image. Empty path → linking disabled
# (NER still emits raw spans to aer_gold.entities). A non-empty
# WIKIDATA_INDEX_SHA256 enforces a fail-fast hash check at worker startup
# to prevent silent index drift; leave empty to skip the check (recommended
# only for development).
WIKIDATA_INDEX_PATH=/data/wikidata/wikidata_aliases.db
WIKIDATA_INDEX_SHA256=
# Image tag for the aer-wikidata-index distribution image, consumed by the
# wikidata-index-init compose service. Pin to a specific snapshot date in
# production; "latest" is acceptable for dev. Quarterly rebuilds via
# .github/workflows/wikidata_index_rebuild.yml.
WIKIDATA_INDEX_TAG=latest

# ==========================================
# WEB CRAWLER (Phase 122)
# ==========================================
#
# Polite User-Agent for the new Python web crawler. WP-006 §5.1 requires
# the crawler to identify itself with a contact address so site
# operators can reach AĒR if a polite-defaults rule is misbehaving.
# Override per environment if you operate the stack on behalf of a
# different organisation.
WEB_CRAWLER_USER_AGENT="AerWebCrawler/0.1 (+https://aer.example/about; mailto:contact@example)"

# ==========================================
# OBSERVABILITY (OpenTelemetry)
# ==========================================
# Phase 122e A8 — endpoint fix.
# All AĒR services run inside Docker, on the `aer-backend` network where
# the OTel collector is reachable as `otel-collector:4318`. The previous
# default `http://localhost:4318` worked only for host-side processes
# bridged via the `aer_debug_ports` socat relay; in-container services
# saw `localhost` as themselves (no listener → connection-refused) and
# silently disabled tracing while flooding logs with retry messages.
# Setting the in-network hostname here makes container traces flow to
# Tempo by default. Operators running services on the host (rare) can
# override per-shell to `http://localhost:4318` — the relay still works.
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=aer-local-stack
# SEC-054/058 — observability footprint (decision D5: keep the FULL stack on in
# prod — metrics + traces + logs — the single box can afford it, and a first
# deploy benefits most from full visibility). The only footprint lever is trace
# SAMPLING: 1.0 (100%) for dev; set 0.1 (10%) in production to bound Tempo trace
# volume on the shared disk while keeping metrics (Prometheus) + logs at 100%.
OTEL_TRACE_SAMPLE_RATE=1.0  # Development: 100%. Production: set 0.1 (10%).

# Dashboard (SvelteKit static adapter) — consumed as Docker build args (Phase 98d).
# The static build inlines these at build time via $env/dynamic/public, so changing
# them requires rebuilding the image (`docker compose build dashboard`).
# Leave PUBLIC_OTLP_ENDPOINT empty to disable browser trace emission entirely.
PUBLIC_OTLP_ENDPOINT=
PUBLIC_DEPLOYMENT_ENVIRONMENT=development

# ==========================================
# GRAFANA
# ==========================================
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=REPLACE-ME
# --- Alert delivery (SEC-037) ----------------------------------------------
# Grafana unified alerting emails the operator when a rule fires (disk-fill, OOM,
# backup stale, corpus frozen, TLS expiry, worker down, …). It sends via Grafana's
# own SMTP, pointed at the SAME Brevo relay as the app (Phase 153). In PRODUCTION
# set GF_SMTP_ENABLED=true and reuse the Brevo SMTP key. Leave disabled in dev
# (alerts still show in the Grafana UI; just no email).
GF_SMTP_ENABLED=false
GF_SMTP_HOST=smtp-relay.brevo.com:587
GF_SMTP_USER=REPLACE-ME            # Brevo SMTP login (same as app SMTP_USERNAME)
GF_SMTP_PASSWORD=REPLACE-ME        # Brevo SMTP key
GF_SMTP_FROM_ADDRESS=alerts@aer-project.eu
GF_SMTP_FROM_NAME=AĒR Alerts
GF_SMTP_STARTTLS_POLICY=MandatoryStartTLS
# Recipient of alert emails (your inbox). NOT hardcoded in the public repo —
# the provisioned contact point reads it from here.
ALERT_EMAIL_TO=REPLACE-ME
# Public origin of this Grafana, so "View alert" links in emails resolve. In prod
# Grafana is NOT publicly routed (SEC-001) — use the SSH-tunnel origin.
GF_SERVER_ROOT_URL=http://localhost:3000

# ==========================================
# TRAEFIK HOST ROUTING
# ==========================================
# Dev defaults use *.example.com with self-signed TLS (no ACME).
# For production with Let's Encrypt, use real domains and run:
#   docker compose -f compose.yaml -f compose.prod.yaml up -d
# NOTE (SEC-001): in PRODUCTION the Grafana + MinIO consoles are NOT publicly
# routed — the prod overlay disables their Traefik routers and you reach them via
# an SSH tunnel (ssh -L 3000:localhost:3000 / -L 9001:localhost:9001). These two
# vars are therefore dev-only; no grafana./minio. DNS records are needed in prod.
GRAFANA_HOST=grafana.example.com
MINIO_CONSOLE_HOST=minio.example.com
# SEC-040 — the canonical public app host (apex domain, no scheme). In PRODUCTION
# the prod overlay scopes the dashboard + /api routers to Host(`${DASHBOARD_HOST}`)
# so the box only answers for this name (not the bare IP / a stray Host header) and
# the ACME cert is requested for it. REQUIRED in prod (preflight.sh enforces it);
# must match BFF_PUBLIC_BASE_URL's host and BFF_WEBAUTHN_RP_ID.
DASHBOARD_HOST=aer.example.com

# ==========================================
# CD / GHCR IMAGE PULL (Phase 150 — M2) — production
# ==========================================
# In production the box PULLS pre-built service images from GHCR instead of
# building locally (compose.prod.yaml pins ghcr.io/${GHCR_OWNER}/aer-<svc>:${IMAGE_TAG}
# and !resets the base build:). Images are published by the release-images.yml
# workflow on a vX.Y.Z tag. The packages are PRIVATE — the box authenticates with
# a read:packages token once (`docker login ghcr.io`); see the deploy runbook.
#
# GHCR_OWNER: the GHCR namespace (your GitHub owner/org). Default frogfromlake.
GHCR_OWNER=frogfromlake
# IMAGE_TAG: which published tag to run. Pin a release (e.g. v1.0.0) for
# reproducible deploys + clean rollback; `latest` tracks the newest tag build.
IMAGE_TAG=latest

# ==========================================
# OFF-BOX BACKUPS (SEC-031/047/049/050) — production
# ==========================================
# scripts/operations/backup.sh (run via `make backup`, scheduled in production)
# backs up Postgres + ClickHouse (native, AMT partitions) + MinIO bronze/silver
# to an ENCRYPTED, in-EU restic repository on a Hetzner Storage Box (D1–D3).
#
# RESTIC_PASSWORD is the client-side encryption key. ESCROW IT OFF-BOX (password
# manager): if it is lost, every backup is permanently unrecoverable — by design
# (a leaked provider cannot read the backups).
# NOTE the path: a Hetzner Storage Box drops the SSH/SFTP session in /home and
# only /home is writable — an absolute ":/aer-backups" (filesystem root) fails
# `restic init` with SSH_FX_FAILURE. Use a path UNDER /home (or a home-relative
# path with no leading slash). SSH/SFTP for Storage Boxes is on PORT 23 — put the
# host + Port 23 + IdentityFile in the host's ~/.ssh/config so restic connects
# non-interactively (see docs/operations/backup_restore.md).
RESTIC_REPOSITORY=sftp:u123456@u123456.your-storagebox.de:/home/aer-backups
RESTIC_PASSWORD=REPLACE-ME
# Retention window (days). 35 (D2) bounds DSGVO right-to-erasure persistence:
# a deleted user ages out of all backups within this window.
BACKUP_RETENTION_DAYS=35
# Where backup.sh writes its Prometheus heartbeat metrics (read by node-exporter
# via --collector.textfile.directory). Create this dir on the host at deploy.
BACKUP_TEXTFILE_DIR=/var/lib/aer/textfile
