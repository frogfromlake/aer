# ==========================================
# REQUIRED SECRETS (boot-validated, Phase 75)
# ==========================================
# The following variables are validated at service start-up. If any of
# them is empty, the affected service refuses to boot with a clear error.
# See docs/operations_playbook.md § "Required Boot Secrets" for the full
# list and where each one is consumed.
#
#   bff-api      → BFF_API_KEY, CLICKHOUSE_PASSWORD
#   ingestion-api → INGESTION_API_KEY, DB_URL (embeds POSTGRES_PASSWORD)
#
# Generate strong API keys with:
#   openssl rand -base64 32
#
# ==========================================
# GLOBAL APP SETTINGS
# ==========================================
APP_ENV=development
LOG_LEVEL=DEBUG

# ==========================================
# INFRASTRUCTURE (DOCKER COMPOSE SECRETS)
# ==========================================
POSTGRES_USER=aer_admin
POSTGRES_PASSWORD=aer_secret  # REQUIRED — embedded in DB_URL
POSTGRES_DB=aer_metadata
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# For local development, uncomment to point to the migrations directory directly.
# Note: do NOT add a "file://" prefix — the ingestion API prepends it automatically.
# MIGRATIONS_PATH=./infra/postgres/migrations

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=change-me  # REQUIRED — bff-api refuses to boot if empty
CLICKHOUSE_DB=aer_gold
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9002

# ==========================================
# NATS MESSAGE BROKER
# ==========================================
NATS_URL=nats://localhost:4222

# ==========================================
# GO SERVICES CONFIGURATION
# ==========================================
INGESTION_PORT=8081
# REQUIRED — ingestion-api refuses to boot if empty
DB_URL=postgres://aer_admin:aer_secret@localhost:5432/aer_metadata?sslmode=disable
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
BFF_PORT=8080
# REQUIRED — bff-api refuses to boot if empty. Generate with `openssl rand -base64 32`.
BFF_API_KEY=change-me-in-production
BFF_METRICS_CACHE_TTL_SECONDS=60
# REQUIRED — ingestion-api refuses to boot if empty. Generate with `openssl rand -base64 32`.
INGESTION_API_KEY=change-me-in-production
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
ACME_EMAIL=your-email@example.com

# ==========================================
# ANALYSIS WORKER (PYTHON)
# ==========================================
WORKER_COUNT=5

# ==========================================
# OBSERVABILITY (OpenTelemetry)
# ==========================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=aer-local-stack
OTEL_TRACE_SAMPLE_RATE=1.0  # Development: 100% sampling. Production recommendation: 0.1 (10%)

# ==========================================
# GRAFANA
# ==========================================
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# ==========================================
# TRAEFIK HOST ROUTING
# ==========================================
# Dev defaults use *.example.com with self-signed TLS (no ACME).
# For production with Let's Encrypt, use real domains and run:
#   docker compose -f compose.yaml -f compose.prod.yaml up -d
GRAFANA_HOST=grafana.example.com
MINIO_CONSOLE_HOST=minio.example.com
