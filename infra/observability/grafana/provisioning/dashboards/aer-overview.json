{
  "uid": "aer-overview",
  "title": "AER Pipeline Overview",
  "tags": ["aer"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "editable": true,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "HTTP Services — Request Rate / Latency / Errors",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 9,
      "title": "Request Rate by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 15, "lineWidth": 2, "spanNulls": false },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (service) (rate(http_server_requests_total[1m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Request Latency p95 by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2, "spanNulls": false },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (service, le) (rate(http_server_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{service}} p95",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "Error Rate (5xx ratio) by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2, "spanNulls": false },
          "unit": "percentunit",
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (service) (rate(http_server_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum by (service) (rate(http_server_requests_total[5m])), 1)",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 101,
      "type": "row",
      "title": "Pipeline — Worker Throughput & Queue",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "title": "Events Processed (rate/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 15, "lineWidth": 2, "spanNulls": false },
          "unit": "cpm"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(events_processed_total[1m]) * 60",
          "legendFormat": "processed",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Events Quarantined (rate/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "fillOpacity": 15, "lineWidth": 2, "spanNulls": false },
          "unit": "cpm"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(events_quarantined_total[1m]) * 60",
          "legendFormat": "quarantined",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "DLQ Size",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "dlq_size",
          "legendFormat": "quarantine objects",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "title": "Event Processing Duration (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 18 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2, "spanNulls": false },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(event_processing_duration_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(event_processing_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(event_processing_duration_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 12,
      "title": "NATS Consumer Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 18 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2, "spanNulls": false },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "pending (undelivered)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "nats_consumer_pending",
          "legendFormat": "pending (undelivered)",
          "refId": "A"
        },
        {
          "expr": "nats_consumer_ack_pending",
          "legendFormat": "ack-pending (in-flight)",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "title": "Events Total (counters)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 18 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "processed" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "quarantined" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "events_processed_total",
          "legendFormat": "processed",
          "refId": "A"
        },
        {
          "expr": "events_quarantined_total",
          "legendFormat": "quarantined",
          "refId": "B"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      }
    },
    {
      "id": 102,
      "type": "row",
      "title": "Infrastructure Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 6,
      "title": "Scrape Targets Up",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 27 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "up",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "horizontal"
      }
    },
    {
      "id": 13,
      "title": "ClickHouse Query Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2, "spanNulls": false },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(ClickHouseProfileEvents_Query[1m])",
          "legendFormat": "queries/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "title": "MinIO Cluster Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2, "spanNulls": false },
          "unit": "bytes"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "minio_cluster_usage_total_bytes",
          "legendFormat": "used",
          "refId": "A"
        }
      ]
    },
    {
      "id": 103,
      "type": "row",
      "title": "Distributed Traces (Tempo)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 7,
      "title": "Recent Traces",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 40 },
      "datasource": { "uid": "tempo", "type": "tempo" },
      "targets": [
        {
          "queryType": "nativeSearch",
          "limit": 20,
          "refId": "A"
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [
          { "displayName": "Start time", "desc": true }
        ]
      }
    },
    {
      "id": 8,
      "title": "Trace Service Map",
      "type": "nodeGraph",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 50 },
      "datasource": { "uid": "tempo", "type": "tempo" },
      "targets": [
        {
          "queryType": "serviceMap",
          "refId": "A"
        }
      ]
    }
  ]
}
